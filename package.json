{
  "name": "contrivox",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "description": "Contrivox — Multilingual AI contract analyser SaaS",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > types/supabase.ts",
    "db:migrate": "supabase migration new",
    "seo:seed": "tsx --env-file=.env.local scripts/seed-clauses.ts",
    "seo:seed-more": "tsx --env-file=.env.local scripts/seed-more-clauses.ts",
    "seo:generate": "tsx --env-file=.env.local scripts/generate.ts",
    "seo:review": "tsx --env-file=.env.local scripts/review-queue.ts",
    "seo:add": "tsx --env-file=.env.local scripts/add-clause.ts",
    "seo:seed-jurisdictions": "tsx --env-file=.env.local scripts/seed-jurisdictions.ts",
    "seo:generate-jurisdictions": "tsx --env-file=.env.local scripts/generate-jurisdiction.ts",
    "seo:publish-jurisdictions": "tsx --env-file=.env.local scripts/auto-publish-jurisdictions.ts",
    "seo:blog": "tsx --env-file=.env.local scripts/generate-blog-articles.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@sentry/nextjs": "10",
    "@strapi/blocks-react-renderer": "^1.0.2",
    "@supabase/ssr": "^0.3.0",
    "@supabase/supabase-js": "^2.43.4",
    "@upstash/ratelimit": "^1.2.1",
    "@upstash/redis": "^1.31.5",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.6.1",
    "gray-matter": "^4.0.3",
    "jspdf": "^4.2.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "next": "14.2.3",
    "posthog-js": "^1.373.5",
    "posthog-node": "^5.34.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^3.2.0",
    "stripe": "^15.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "jest": "^29.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5"
  }
}
