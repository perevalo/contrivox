# Contrivox — Environment Variables Template
# Copy to .env.local for local development
# NEVER commit .env.local or .env to git
# All secrets managed via Vercel dashboard in production

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...           # safe for client
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # server only — never expose

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                   # server only — never expose

# ── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_... # safe for client
STRIPE_SECRET_KEY=sk_live_...                  # server only — never expose
STRIPE_WEBHOOK_SECRET=whsec_...                # server only — never expose

# Stripe Price IDs (create in Stripe dashboard — one-time payments)
STRIPE_PRICE_BASIC_USD=price_...               # $9.00 basic analysis (on-screen)
STRIPE_PRICE_PRO_USD=price_...                 # $29.00 full report (on-screen + PDF + email)
STRIPE_PRICE_UPGRADE_USD=price_...             # $15.00 upgrade: basic → full report

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...                          # server only — never expose
RESEND_FROM_EMAIL=reports@contrivox.com

# ── Upstash Redis (rate limiting) ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...                   # server only — never expose

# ── PostHog ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...                # Project API key (safe for client)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com  # or https://eu.i.posthog.com

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=https://contrivox.com          # no trailing slash
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FB_PIXEL_ID=XXXXXXXXXXXXXXXXX

# ── Cache revalidation ────────────────────────────────────────────────────────
NEXT_REVALIDATE_SECRET=replace-with-random-secret   # server only — never expose

# ── Sentry ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...  # DSN (safe for client)
SENTRY_AUTH_TOKEN=sntrys_...                                   # Build-time source maps upload — server only
SENTRY_ORG=your-org-slug                                       # Sentry org slug
SENTRY_PROJECT=contrivox                                       # Sentry project slug
